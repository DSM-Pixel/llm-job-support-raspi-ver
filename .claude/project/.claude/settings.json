{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "fable",
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(uvx:*)",
      "Bash(pip:*)",
      "Bash(pip install:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(ruff format:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)",
      "Bash(gradio:*)",
      "Bash(streamlit run:*)",
      "Bash(uvicorn:*)",
      "Bash(./run_web.sh:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "PowerShell(uv:*)",
      "PowerShell(uvx:*)",
      "PowerShell(python:*)",
      "PowerShell(pytest:*)",
      "PowerShell(ruff:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Test-Path:*)",
      "PowerShell(New-Item:*)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:data.go.kr)",
      "WebFetch(domain:www.data.go.kr)",
      "WebFetch(domain:apis.data.go.kr)",
      "WebFetch(domain:gradio.app)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:python.langchain.com)",
      "WebFetch(domain:docs.llamaindex.ai)",
      "WebFetch(domain:ai.google.dev)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(rm:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "PowerShell(Remove-Item -Recurse -Force C:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env)",
      "Read(**/credentials.json)",
      "Read(**/service-account*.json)",
      "Read(backend/storage/users.db)"
    ]
  },
  "env": {
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1",
    "ANTHROPIC_MODEL": "",
    "ANTHROPIC_SMALL_FAST_MODEL": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-secrets.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-on-save.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/session_start.py"
          }
        ]
      }
    ]
  }
}
